    "nuxt": "^4.2.0",
    "nuxt-toast": "^1.4.0",
    "pinia": "^3.0.3",
    "pinia-plugin-persistedstate": "^4.7.1",
    "tailwind-merge": "^3.3.1",
    "vue": "^3.5.22",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/eslint-config-prettier": "^6.11.3",

{
  "name": "nuxtjs-template",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nuxt dev --dotenv .env.local",
    "build": "nuxt build",
    "start": "bun .output/server/index.mjs",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "nuxt typecheck",
    "lint": "prettier ./ --check && eslint . && nuxt typecheck",
    "fix": "prettier ./ --write && eslint . --fix && nuxt typecheck && bun outdated"
  },
  "dependencies": {
    "@nuxt/fonts": "0.14.0",
    "@nuxt/icon": "2.2.1",
    "@nuxt/image": "2.0.0",
    "@nuxt/scripts": "0.13.2",
    "@nuxt/eslint": "1.15.1",
    "@tailwindcss/vite": "^4.2.1",
    "@pinia/nuxt": "^0.11.3",
    "@unhead/vue": "^2.1.4",
    "izitoast": "^1.4.0",
    "lodash-es": "^4.17.23",
    "nuxt": "^4.3.1",
    "nuxt-toast": "^1.4.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "vue": "^3.5.28"
  },
  "devDependencies": {
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^25.3.0",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "vue-tsc": "^3.2.5"
  }
}
